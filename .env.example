OPENAI_API_KEY=sk-proj-...
NEXT_PUBLIC_CHATKIT_WORKFLOW_ID=wf_...

# Google Cloud Storage for shared workflow persistence
WORKFLOWS_GCS_BUCKET=your-bucket-name
WORKFLOWS_GCS_PATH=chatkit/workflows.json

# Optional: GCS credentials JSON (set as Cloud Run secret)
# If not set, uses Application Default Credentials automatically
# GCS_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
